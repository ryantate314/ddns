# Full invoke URL for the /update endpoint (from `terraform output -raw api_invoke_url`).
API_URL="https://abc123xyz.execute-api.us-east-1.amazonaws.com/prod/update"

# API key from `terraform output -raw api_key_value`.
API_KEY="REPLACE_ME"

# FQDN this client is updating. Informational only (the Lambda decides the real record).
RECORD_NAME="home.example.com"

# Network interface on the LXC whose IPv6 address should be reported.
# Find it with `ip -o -6 addr show scope global` and pick the iface with your ISP-routed /64.
IPV6_IFACE="eth0"
